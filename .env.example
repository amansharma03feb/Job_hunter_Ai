# Copy this to .env and fill in your real secrets (do not commit .env)

# Telegram Bot (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=959971760

# Apify — LinkedIn scraper (required for LinkedIn scraping)
# Get free token at: https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# Anthropic — Claude API for AI scoring (optional, falls back to keyword scoring)
# Get API key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
