# Copy this to .env and fill in your real secrets (do not commit .env)

# Telegram Bot (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=959971760

# Apify — LinkedIn scraper (required)
# Get token at: https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# Anthropic — Claude API for AI scoring + resume tailoring (recommended)
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail — for sending tailored application emails (optional)
# Use an App Password (NOT your real password):
#   myaccount.google.com → Security → 2FA on → App Passwords → Mail
GMAIL_ADDRESS=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Hunter.io — email validation (optional, 25 free/month)
# Get key at: https://hunter.io/api-keys
HUNTER_API_KEY=your_hunter_api_key_here
